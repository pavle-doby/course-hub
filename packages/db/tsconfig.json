{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "baseUrl": ".",
    "noEmit": false,
    "paths": {
      "@my/db-schema": ["../db-schema/src/index.ts"],
      "@my/db-schema/*": ["../db-schema/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../db-schema"
    }
  ]
}
