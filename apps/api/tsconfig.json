{
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "api/*": ["src/*"],
      "api": ["src"],
      "@repo/db": ["../../packages/db/src/index.ts"],
      "@repo/db/*": ["../../packages/db/src/*"],
      "@repo/db-schema": ["../../packages/db-schema/src/index.ts"],
      "@repo/db-schema/*": ["../../packages/db-schema/src/*"],
      "@repo/contract": ["../../packages/contract/src/index.ts"],
      "@repo/contract/*": ["../../packages/contract/src/*"]
    },
    "lib": ["es2022"],
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "src/types/env.d.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../packages/db-schema"
    },
    {
      "path": "../../packages/contract"
    }
  ]
}
