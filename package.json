{
  "name": "course-hub",
  "private": true,
  "scripts": {
    "web": "pnpm --filter web dev",
    "api": "pnpm --filter api dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "cd packages/db && pnpm exec drizzle-kit generate",
    "db:push": "cd packages/db && pnpm exec drizzle-kit push",
    "db:migrate": "cd packages/db && pnpm exec drizzle-kit migrate",
    "db:studio": "cd packages/db && pnpm exec drizzle-kit studio",
    "db:clean:users": "pnpm --filter @repo/scripts run db:clean:users",
    "db:seed:users": "pnpm --filter @repo/scripts run db:seed:users",
    "generate": "turbo run generate:openapi generate:api"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0"
    }
  }
}
